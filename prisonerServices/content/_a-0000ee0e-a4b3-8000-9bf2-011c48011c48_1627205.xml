    <rule>
        <name>PS_ReplacePlaceHoldersWithRecordData</name>
        <uuid>_a-0000ee0e-a4b3-8000-9bf2-011c48011c48_1627205</uuid>
        <description></description>
        <parentUuid>4e30e89d-6b0d-415f-8a87-1107bebc8692</parentUuid>
        <visibility>
            <advertise>false</advertise>
            <hierarchy>true</hierarchy>
            <indexable>true</indexable>
            <quota>false</quota>
            <searchable>true</searchable>
            <system>false</system>
            <unlogged>false</unlogged>
        </visibility>
        <definition>a!localVariables(
  local!keys: a!flatten(
    #"SYSTEM_SYSRULES_forEach"(
      items: a!keys(ri!data),
      expression: if(
        runtimetypeof(ri!data[fv!item]) = 'type!{http://www.appian.com/ae/types/2009}Map',
        a!localVariables(
          parentKey: fv!item,
          #"SYSTEM_SYSRULES_forEach"(
            items: a!keys(ri!data[fv!item]),
            expression: a!map(
              placeholder: concat("{", local!parentKey, ".", fv!item, "}"),
              path: concat(local!parentKey, ".", fv!item)
            )
          )
        ),
        a!map(
          placeholder: concat("{", tostring(fv!item), "}"),
          path: tostring(fv!item)
        )
      )
    )
  ),
  if(
    a!isNullOrEmpty(local!keys),
    ri!template,
    reduce(
      substitute(_,_,_),
      ri!template,
      merge(
        local!keys.placeholder,
        #"SYSTEM_SYSRULES_forEach"(
          items: local!keys.path,
          expression: a!localVariables(
            local!value: #"_a-0000ee0e-a4b3-8000-9bf2-011c48011c48_1627212"(data: ri!data, path: fv!item, default: null),
            if(
              a!isNullOrEmpty(local!value),
              "",
              a!match(
                value: typeof(local!value),
                
                whenTrue: fv!value = 'type!{http://www.appian.com/ae/types/2009}User',
                then: #"_a-0000ee0e-a4b3-8000-9bf2-011c48011c48_1546843"(user: local!value),
                
                whenTrue: fv!value = 'type!{http://www.appian.com/ae/types/2009}Decimal',
                then: #"urn:appian:function:v1:a:currency"("EUR", local!value),
      
                whenTrue: fv!value = 'type!{http://www.appian.com/ae/types/2009}Date',
                then: text(local!value, "dd mmmm yyyy"),
      
                whenTrue: fv!value = 'type!{http://www.appian.com/ae/types/2009}Datetime',
                then: text(local!value, "dd mmmm yyyy hh:mm"),
      
                default: local!value
              )
            )
          )
        )
      )
    )
  )
)
</definition>
