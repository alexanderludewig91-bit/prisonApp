<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<contentHaul xmlns:a="http://www.appian.com/ae/types/2009">
    <versionUuid>_a-0000ee0e-a4b3-8000-9bf2-011c48011c48_1696736</versionUuid>
    <rule>
        <name>PS_DR_DateMonth</name>
        <uuid>_a-0000ee0e-a4b3-8000-9bf2-011c48011c48_1683430</uuid>
        <description>Format 1. Januar 2025</description>
        <parentUuid>4e30e89d-6b0d-415f-8a87-1107bebc8692</parentUuid>
        <visibility>
            <advertise>false</advertise>
            <hierarchy>true</hierarchy>
            <indexable>true</indexable>
            <quota>false</quota>
            <searchable>true</searchable>
            <system>false</system>
            <unlogged>false</unlogged>
        </visibility>
        <definition>if(
  a!isNullOrEmpty(ri!date),
  "--",
  text(ri!date, "dd mmmm yyyy"),
)</definition>
        <namedTypedValue>
            <name>date</name>
            <type>
                <name>date</name>
                <namespace>http://www.w3.org/2001/XMLSchema</namespace>
            </type>
        </namedTypedValue>
        <preferredEditor>legacy</preferredEditor>
        <offlineEnabled>false</offlineEnabled>
    </rule>
    <roleMap public="true">
        <role inherit="true" allowForAll="false" name="readers">
            <users/>
            <groups/>
        </role>
        <role inherit="true" allowForAll="false" name="authors">
            <users/>
            <groups/>
        </role>
        <role inherit="true" allowForAll="false" name="administrators">
            <users/>
            <groups/>
        </role>
        <role inherit="false" allowForAll="false" name="denyReaders">
            <users/>
            <groups/>
        </role>
        <role inherit="false" allowForAll="false" name="denyAuthors">
            <users/>
            <groups/>
        </role>
        <role inherit="false" allowForAll="false" name="denyAdministrators">
            <users/>
            <groups/>
        </role>
    </roleMap>
    <typedValue>
        <type>
            <name>RuleTestConfig?list</name>
            <namespace>http://www.appian.com/ae/types/2009</namespace>
        </type>
        <value>
            <el>
                <a:name>Formats date correctly</a:name>
                <a:ruleInputTestConfigs>
                    <a:value xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:type="a:Expression">date(2025, 1, 1)</a:value>
                    <a:nameRef>date</a:nameRef>
                    <a:id>1</a:id>
                </a:ruleInputTestConfigs>
                <a:assertions>
                    <a:expectedOutput>
                        <a:type a:uuid="{http://www.appian.com/ae/types/2009}Text"/>
                        <a:runtimeType a:uuid="{http://www.appian.com/ae/types/2009}Text"/>
                        <a:value xmlns:xsd="http://www.w3.org/2001/XMLSchema" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:type="xsd:string">01 January 2025</a:value>
                    </a:expectedOutput>
                </a:assertions>
                <a:isDefault>false</a:isDefault>
            </el>
            <el>
                <a:name>Handles null date</a:name>
                <a:ruleInputTestConfigs>
                    <a:value xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:type="a:Expression">null</a:value>
                    <a:nameRef>date</a:nameRef>
                    <a:id>1</a:id>
                </a:ruleInputTestConfigs>
                <a:assertions>
                    <a:expectedOutput>
                        <a:type a:uuid="{http://www.appian.com/ae/types/2009}Text"/>
                        <a:runtimeType a:uuid="{http://www.appian.com/ae/types/2009}Text"/>
                        <a:value xmlns:xsd="http://www.w3.org/2001/XMLSchema" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:type="xsd:string">--</a:value>
                    </a:expectedOutput>
                </a:assertions>
                <a:isDefault>false</a:isDefault>
            </el>
            <el>
                <a:name>Formats date with single-digit day</a:name>
                <a:ruleInputTestConfigs>
                    <a:value xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:type="a:Expression">date(2025, 12, 5)</a:value>
                    <a:nameRef>date</a:nameRef>
                    <a:id>1</a:id>
                </a:ruleInputTestConfigs>
                <a:assertions>
                    <a:expectedOutput>
                        <a:type a:uuid="{http://www.appian.com/ae/types/2009}Text"/>
                        <a:runtimeType a:uuid="{http://www.appian.com/ae/types/2009}Text"/>
                        <a:value xmlns:xsd="http://www.w3.org/2001/XMLSchema" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:type="xsd:string">05 December 2025</a:value>
                    </a:expectedOutput>
                </a:assertions>
                <a:isDefault>false</a:isDefault>
            </el>
            <el>
                <a:name>Formats date at year boundary</a:name>
                <a:ruleInputTestConfigs>
                    <a:value xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:type="a:Expression">date(2025, 12, 31)</a:value>
                    <a:nameRef>date</a:nameRef>
                    <a:id>1</a:id>
                </a:ruleInputTestConfigs>
                <a:assertions>
                    <a:expectedOutput>
                        <a:type a:uuid="{http://www.appian.com/ae/types/2009}Text"/>
                        <a:runtimeType a:uuid="{http://www.appian.com/ae/types/2009}Text"/>
                        <a:value xmlns:xsd="http://www.w3.org/2001/XMLSchema" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:type="xsd:string">31 December 2025</a:value>
                    </a:expectedOutput>
                </a:assertions>
                <a:isDefault>false</a:isDefault>
            </el>
            <el>
                <a:name>Formats leap year date</a:name>
                <a:ruleInputTestConfigs>
                    <a:value xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:type="a:Expression">date(2024, 2, 29)</a:value>
                    <a:nameRef>date</a:nameRef>
                    <a:id>1</a:id>
                </a:ruleInputTestConfigs>
                <a:assertions>
                    <a:expectedOutput>
                        <a:type a:uuid="{http://www.appian.com/ae/types/2009}Text"/>
                        <a:runtimeType a:uuid="{http://www.appian.com/ae/types/2009}Text"/>
                        <a:value xmlns:xsd="http://www.w3.org/2001/XMLSchema" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:type="xsd:string">29 February 2024</a:value>
                    </a:expectedOutput>
                </a:assertions>
                <a:isDefault>false</a:isDefault>
            </el>
        </value>
    </typedValue>
