        <definition>if(
  or(
    a!isNullOrEmpty(ri!prisonId),
    a!isNullOrEmpty(ri!eventId)
  ),
  #"urn:appian:translation-string:v1:bb28a034-f771-46fc-a9aa-e75951612806",
  concat(
    a!defaultValue(ri!prisonId, "JVA"),
    " ",
    "4514",
    "/",
    "V",
    "-",
    datetext(now(), "yyyy"),
    ".",
    a!defaultValue(
      ri!eventId,
      concat(
        #"urn:appian:translation-string:v1:5f18fc35-6124-485e-82fc-8e328a1ce1e5",
        "ID"
      )
    ),
    
  )
)</definition>
