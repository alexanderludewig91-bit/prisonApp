    <versionUuid>_a-0000ee0e-a4b3-8000-9bf2-011c48011c48_1627218</versionUuid>
    <rule>
        <name>PS_DeepIndex</name>
        <uuid>_a-0000ee0e-a4b3-8000-9bf2-011c48011c48_1627212</uuid>
        <description>Navigate in a deep data structure in a null-save way. Example: rule!BCO_DeepIndex({a:{b:{"one", "two"}}}, {"a", "b", 2}, "") yields "two".</description>
        <parentUuid>4e30e89d-6b0d-415f-8a87-1107bebc8692</parentUuid>
        <visibility>
            <advertise>false</advertise>
            <hierarchy>true</hierarchy>
            <indexable>true</indexable>
            <quota>false</quota>
            <searchable>true</searchable>
            <system>false</system>
            <unlogged>false</unlogged>
        </visibility>
        <definition>if(
  a!isNullOrEmpty(ri!path),
  ri!data,
  reduce(
    index(_,_,ri!default),
    ri!data,
    a!match(
      value: typeof(ri!path),
      
      /* Format like "fieldParent.3.fieldChild" */
      whenTrue: fv!value = 'type!{http://www.appian.com/ae/types/2009}Text',
      then: #"SYSTEM_SYSRULES_forEach"(
        items: split(ri!path, "."),
        expression: if(
          exact(tostring(tointeger(fv!item)), fv!item),
          tointeger(fv!item),
          fv!item
        )
      ),
      
      /* Format like {"fieldParent", 3, "fieldChild"} */
      whenTrue: count(ri!path) &gt; 1,
      then: ri!path,
      
      /* Others, probably record fields. Must be a list to calm the reduce function. */
      default: {ri!path}
    )
  )
)</definition>
        <namedTypedValue>
            <name>data</name>
            <type>
                <name>Variant</name>
                <namespace>http://www.appian.com/ae/types/2009</namespace>
            </type>
        </namedTypedValue>
        <namedTypedValue>
            <name>path</name>
            <type>
                <name>Variant</name>
                <namespace>http://www.appian.com/ae/types/2009</namespace>
            </type>
        </namedTypedValue>
        <namedTypedValue>
            <name>default</name>
            <type>
                <name>Variant</name>
                <namespace>http://www.appian.com/ae/types/2009</namespace>
            </type>
        </namedTypedValue>
        <preferredEditor>legacy</preferredEditor>
        <offlineEnabled>false</offlineEnabled>
    </rule>
