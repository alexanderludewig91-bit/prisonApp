    <rule>
        <name>PS_GetActivityByRecord</name>
        <uuid>_a-0000ed02-f63d-8000-9bea-011c48011c48_1058849</uuid>
        <description>Returns all activity history for a single record [Activity History] [Data]</description>
        <parentUuid>bb69cd5d-2b14-4fb7-b9d0-11ebd5815cda</parentUuid>
        <visibility>
            <advertise>false</advertise>
            <hierarchy>true</hierarchy>
            <indexable>true</indexable>
            <quota>false</quota>
            <searchable>true</searchable>
            <system>false</system>
            <unlogged>false</unlogged>
        </visibility>
        <definition>#"SYSTEM_SYSRULES_queryEntity_v2"(
  entity: #"cf7e3f07-946f-4516-83c3-f4171998339f_CHANGEDSECONSTANT",
  query: #"SYSTEM_SYSRULES_query"(
    logicalExpression: #"SYSTEM_SYSRULES_queryLogicalExpression"(
      operator: "AND",
      filters: {
        #"SYSTEM_SYSRULES_queryFilter"(
          field: "recordId",
          operator: "=",
          value: ri!recordId
        ),
        if(
          isnull(ri!userFilter),
          {},
          #"SYSTEM_SYSRULES_queryFilter"(
            field: "who",
            operator: "=",
            value: ri!userFilter
          )
        )
      },
      logicalExpressions: if(
        isnull(ri!searchTerm),
        {},
        #"SYSTEM_SYSRULES_queryLogicalExpression"(
          operator: "OR",
          filters: {
            #"SYSTEM_SYSRULES_queryFilter"(
              field: "action",
              operator: "includes",
              value: ri!searchTerm
            ),
            #"SYSTEM_SYSRULES_queryFilter"(
              field: "details",
              operator: "includes",
              value: ri!searchTerm
            )
          }
        )
      )
    ),
    pagingInfo: ri!pagingInfo
  ),
  fetchTotalCount: true
)</definition>
        <namedTypedValue>
            <name>recordId</name>
            <type>
                <name>int</name>
                <namespace>http://www.w3.org/2001/XMLSchema</namespace>
            </type>
        </namedTypedValue>
        <namedTypedValue>
            <name>searchTerm</name>
            <type>
                <name>string</name>
                <namespace>http://www.w3.org/2001/XMLSchema</namespace>
            </type>
            <value/>
        </namedTypedValue>
        <namedTypedValue>
            <name>userFilter</name>
            <type>
                <name>User</name>
                <namespace>http://www.appian.com/ae/types/2009</namespace>
            </type>
        </namedTypedValue>
        <namedTypedValue>
            <name>pagingInfo</name>
            <type>
                <name>PagingInfo</name>
                <namespace>http://www.appian.com/ae/types/2009</namespace>
            </type>
        </namedTypedValue>
        <preferredEditor>legacy</preferredEditor>
        <offlineEnabled>false</offlineEnabled>
    </rule>
