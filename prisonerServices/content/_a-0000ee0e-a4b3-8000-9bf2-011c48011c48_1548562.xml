                <a:ruleInputTestConfigs>
                    <a:value xmlns:xsd="http://www.w3.org/2001/XMLSchema" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:nil="true" xsi:type="xsd:int"/>
                    <a:nameRef>eventId</a:nameRef>
                    <a:id>1</a:id>
                </a:ruleInputTestConfigs>
                <a:assertions>
                    <a:expectedOutput>
                        <a:type a:uuid="{http://www.appian.com/ae/types/2009}Map"/>
                        <a:runtimeType a:uuid="{http://www.appian.com/ae/types/2009}Map"/>
                        <a:value xmlns:xsd="http://www.w3.org/2001/XMLSchema" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:type="a:Map"/>
                    </a:expectedOutput>
                </a:assertions>
                <a:isDefault>false</a:isDefault>
            </el>
            <el>
                <a:name>Handles non-existent eventId</a:name>
                <a:ruleInputTestConfigs>
                    <a:value xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:type="a:Expression">999</a:value>
                    <a:nameRef>eventId</a:nameRef>
                    <a:id>1</a:id>
                </a:ruleInputTestConfigs>
                <a:assertions>
                    <a:expectedOutput xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:nil="true"/>
                    <a:resultAssertions>and(isnull(test!output.event), isnull(test!output.participants))</a:resultAssertions>
                </a:assertions>
                <a:isDefault>false</a:isDefault>
            </el>
            <el>
                <a:name>Handles zero as eventId</a:name>
                <a:ruleInputTestConfigs>
                    <a:value xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:type="a:Expression">0</a:value>
                    <a:nameRef>eventId</a:nameRef>
                    <a:id>1</a:id>
                </a:ruleInputTestConfigs>
                <a:assertions>
                    <a:expectedOutput xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:nil="true"/>
                    <a:resultAssertions>and(isnull(test!output.event), isnull(test!output.participants))</a:resultAssertions>
                </a:assertions>
                <a:isDefault>false</a:isDefault>
            </el>
        </value>
