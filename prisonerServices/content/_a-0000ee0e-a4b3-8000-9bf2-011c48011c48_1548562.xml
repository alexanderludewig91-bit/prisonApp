    <rule>
        <name>PS_Q_GetEventAndParticipantsByEventId</name>
        <uuid>_a-0000ee0e-a4b3-8000-9bf2-011c48011c48_1548562</uuid>
        <description></description>
        <parentUuid>4e30e89d-6b0d-415f-8a87-1107bebc8692</parentUuid>
        <visibility>
            <advertise>false</advertise>
            <hierarchy>true</hierarchy>
            <indexable>true</indexable>
            <quota>false</quota>
            <searchable>true</searchable>
            <system>false</system>
            <unlogged>false</unlogged>
        </visibility>
        <definition>if(
  a!isNullOrEmpty(ri!eventId),
  a!map(
    event: null,
    participants: null
  ),
  a!localVariables(
    local!pagingInfo: #"SYSTEM_SYSRULES_pagingInfo"(startIndex: 1,batchSize: 100),
    local!eventParticipants: #"SYSTEM_SYSRULES_queryRecordType_v2"(
      recordType: #"urn:appian:record-type:v1:1fe6b14d-867b-40df-9f1c-c21276750514",
      filters: #"SYSTEM_SYSRULES_queryFilter"(
        field: #"urn:appian:record-field:v1:1fe6b14d-867b-40df-9f1c-c21276750514/5589f1fc-eabe-4cfb-b40a-0a3b62b5358a",
        operator: "=",
        value: ri!eventId
      ),
      pagingInfo: local!pagingInfo
    ).data,
    local!event: if(
      a!isNullOrEmpty(local!eventParticipants[#"urn:appian:record-field:v1:1fe6b14d-867b-40df-9f1c-c21276750514/f47d3f62-8d37-4e49-aeff-c4b38fcbcdd3"]),
      null,
      #"SYSTEM_SYSRULES_queryRecordType_v2"(
        recordType: #"urn:appian:record-type:v1:fa952da3-a305-45ce-924b-89ca2dab3222",
        filters: #"SYSTEM_SYSRULES_queryFilter"(
          field: #"urn:appian:record-field:v1:fa952da3-a305-45ce-924b-89ca2dab3222/8eedcd4f-41f4-4085-889b-efedecf448e2",
          operator: "in",
          value: local!eventParticipants[#"urn:appian:record-field:v1:1fe6b14d-867b-40df-9f1c-c21276750514/5589f1fc-eabe-4cfb-b40a-0a3b62b5358a"]
        ),
        pagingInfo: local!pagingInfo
      )
    ),
    local!participants: if(
      a!isNullOrEmpty(local!eventParticipants[#"urn:appian:record-field:v1:1fe6b14d-867b-40df-9f1c-c21276750514/f47d3f62-8d37-4e49-aeff-c4b38fcbcdd3"]),
      null,
      #"SYSTEM_SYSRULES_queryRecordType_v2"(
        recordType: #"urn:appian:record-type:v1:3854eb39-6a61-48cd-82b6-e4645b2900fe",
        filters: #"SYSTEM_SYSRULES_queryFilter"(
          field: #"urn:appian:record-field:v1:3854eb39-6a61-48cd-82b6-e4645b2900fe/cdeaab86-f2b7-4659-8893-494922e7e85a",
          operator: "in",
          value: local!eventParticipants[#"urn:appian:record-field:v1:1fe6b14d-867b-40df-9f1c-c21276750514/f47d3f62-8d37-4e49-aeff-c4b38fcbcdd3"]
        ),
        pagingInfo: local!pagingInfo
      )
    ),
    a!map(
      event: local!event.data,
      participants: local!participants.data
    )
  )
)</definition>
        <namedTypedValue>
            <name>eventId</name>
            <type>
                <name>int</name>
                <namespace>http://www.w3.org/2001/XMLSchema</namespace>
            </type>
        </namedTypedValue>
        <preferredEditor>legacy</preferredEditor>
        <offlineEnabled>false</offlineEnabled>
    </rule>
