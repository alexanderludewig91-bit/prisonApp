          ),
          "$NAME_DES_PRODUKTS",
          "Prisoner Services"
        ),
        "$HERSTELLER",
        "AV SOFTWARE SOLUTIONS 360°"
      ),
      "$SOFTWAREVERSION",
      "Version 1.0"
    )toxml(
      replaceb(
        local!firstXMLVersion,
        sum(
          len(
