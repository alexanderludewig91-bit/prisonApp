          )
        ) + len(
          "&lt;tns:natuerlichePerson&gt;
&lt;tns:vollerName&gt;
&lt;tns:vorname&gt;$VORNAME&lt;/tns:vorname&gt;
&lt;tns:nachname&gt;$NACHNAME&lt;/tns:nachname&gt;
&lt;/tns:vollerName&gt;
&lt;tns:geburt&gt;
&lt;!-- TeT-Comment: \d{4}((-\d{2}){0,1}-\d{2}){0,1} --&gt;
&lt;tns:geburtsdatum&gt;$GEBURTSDATUM&lt;/tns:geburtsdatum&gt;
&lt;/tns:geburt&gt;
&lt;/tns:natuerlichePerson&gt;"
        ),
        concat(
          local!participantsData &amp; "
&lt;/tns:verfahrensdaten&gt;
&lt;/tns:grunddaten&gt;
&lt;/tns:nachricht.gds.basisnachricht.0005006&gt;"
        )
      )
    )
  )
)</definition>
