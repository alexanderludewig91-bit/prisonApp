        <definition>if(
  a!isNullOrEmpty(ri!eventId),
  toxml("No eventId found"),
  a!localVariables(
    local!eventData: #"_a-0000ee0e-a4b3-8000-9bf2-011c48011c48_1548562"(eventId: ri!eventId),
    local!participantsData: concat(
      #"SYSTEM_SYSRULES_forEach"(
        items: local!eventData.participants,
        expression: concat(
          "
&lt;tns:beteiligung&gt;
&lt;tns:rolle&gt;
&lt;!-- TeT-Comment: Eindeutig innerhalb des Dokuments --&gt;
&lt;tns:rollennummer&gt;" &amp; fv!item[#"urn:appian:record-field:v1:3854eb39-6a61-48cd-82b6-e4645b2900fe/6e4c5732-924a-42ac-8c76-c8abc7bd517f"] &amp; "&lt;/tns:rollennummer&gt;
&lt;tns:rollenbezeichnung listVersionID="3.5"&gt;
&lt;!-- TeT-Comment: ZEUGEN, Beispielhaft nur diese Rolle --&gt;
&lt;code&gt;202&lt;/code&gt;
&lt;/tns:rollenbezeichnung&gt;
&lt;!-- TeT-Comment: Fortlaufend je 202-202 Zeuge, Zeugin --&gt;
&lt;tns:nr&gt;1&lt;/tns:nr&gt;
&lt;!-- TeT-Comment: User-ID --&gt;
&lt;tns:geschaeftszeichen&gt;" &amp; fv!item[#"urn:appian:record-field:v1:3854eb39-6a61-48cd-82b6-e4645b2900fe/5bd820c3-9636-46f6-a807-71831615e1ae"] &amp; "&lt;/tns:geschaeftszeichen&gt;
&lt;/tns:rolle&gt;
&lt;tns:beteiligter&gt;
&lt;tns:auswahl_beteiligter&gt;
&lt;tns:natuerlichePerson&gt;
&lt;tns:vollerName&gt;
&lt;tns:vorname&gt;" &amp; #"_a-0000ee0e-a4b3-8000-9bf2-011c48011c48_1566080"(
            fv!item[#"urn:appian:record-field:v1:3854eb39-6a61-48cd-82b6-e4645b2900fe/02011db0-86ad-4cf2-bf76-8358c5fd0dc2"]
          ) &amp; "&lt;/tns:vorname&gt;
&lt;tns:nachname&gt;" &amp; #"_a-0000ee0e-a4b3-8000-9bf2-011c48011c48_1566103"(
            fv!item[#"urn:appian:record-field:v1:3854eb39-6a61-48cd-82b6-e4645b2900fe/02011db0-86ad-4cf2-bf76-8358c5fd0dc2"]
          ) &amp; "&lt;/tns:nachname&gt;
&lt;/tns:vollerName&gt;
&lt;tns:geburt&gt;
&lt;!-- TeT-Comment: \d{4}((-\d{2}){0,1}-\d{2}){0,1} --&gt;
&lt;tns:geburtsdatum&gt;" &amp; fv!item[#"urn:appian:record-field:v1:3854eb39-6a61-48cd-82b6-e4645b2900fe/bbb02f76-6d20-4cc7-b768-a46ba483418d"] &amp; "&lt;/tns:geburtsdatum&gt;
&lt;/tns:geburt&gt;
&lt;/tns:natuerlichePerson&gt;
&lt;/tns:auswahl_beteiligter&gt;
&lt;/tns:beteiligter&gt;
&lt;/tns:beteiligung&gt;"
        ),
        
      )
    ),
    local!firstXMLVersion: substitute(
      substitute(
        substitute(
          substitute(
            substitute(
              substitute(
                substitute(
                  substitute(
                    #"_a-0000ee0e-a4b3-8000-9bf2-011c48011c48_1548527",
                    "$AKTENZEICHEN",
