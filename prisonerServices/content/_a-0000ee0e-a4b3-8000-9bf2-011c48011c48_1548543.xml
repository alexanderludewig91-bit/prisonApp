                  ),
                  "$AKTENZEICHEN_EMPFAENGER",
                  "1234"
                ),
                "$NACHRICHTENID",
                concat(
                  "Nachricht: " &amp; local!eventData.event[#"urn:appian:record-field:v1:fa952da3-a305-45ce-924b-89ca2dab3222/8eedcd4f-41f4-4085-889b-efedecf448e2"] &amp; "/Intern"
                )
              ),
              "$ERSTELLUNGSZEITPUNKT_MELDUNG",
