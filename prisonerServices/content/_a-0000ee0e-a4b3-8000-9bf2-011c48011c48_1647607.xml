    <rule>
        <name>PS_DR_DateTimeMonthOptionalHour</name>
        <uuid>_a-0000ee0e-a4b3-8000-9bf2-011c48011c48_1647607</uuid>
        <description>Format 1. Januar 2025 with optional Hour</description>
        <parentUuid>4e30e89d-6b0d-415f-8a87-1107bebc8692</parentUuid>
        <visibility>
            <advertise>false</advertise>
            <hierarchy>true</hierarchy>
            <indexable>true</indexable>
            <quota>false</quota>
            <searchable>true</searchable>
            <system>false</system>
            <unlogged>false</unlogged>
        </visibility>
        <definition>if(
  a!isNullOrEmpty(ri!dateTime),
  "--",
  if(
    ri!hour,
    text(ri!dateTime, "hh:mm"),
    if(
      ri!month,
      text(ri!dateTime, "dd mmmm yyyy"),
      text(ri!dateTime, "dd mmmm yyyy hh:mm")
    )
  )
)</definition>
        <namedTypedValue>
            <name>dateTime</name>
            <type>
                <name>dateTime</name>
                <namespace>http://www.w3.org/2001/XMLSchema</namespace>
            </type>
        </namedTypedValue>
        <namedTypedValue>
            <name>hour</name>
            <type>
                <name>boolean</name>
                <namespace>http://www.w3.org/2001/XMLSchema</namespace>
            </type>
        </namedTypedValue>
        <namedTypedValue>
            <name>month</name>
            <type>
                <name>boolean</name>
                <namespace>http://www.w3.org/2001/XMLSchema</namespace>
            </type>
        </namedTypedValue>
        <preferredEditor>legacy</preferredEditor>
        <offlineEnabled>false</offlineEnabled>
    </rule>
