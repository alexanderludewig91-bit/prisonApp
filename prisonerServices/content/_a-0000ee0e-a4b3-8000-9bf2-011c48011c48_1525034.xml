        <name>PS_C_FileUploadField</name>
        <uuid>_a-0000ee0e-a4b3-8000-9bf2-011c48011c48_1525034</uuid>
        <description></description>
        <parentUuid>4e30e89d-6b0d-415f-8a87-1107bebc8692</parentUuid>
        <visibility>
            <advertise>false</advertise>
            <hierarchy>true</hierarchy>
            <indexable>true</indexable>
            <quota>false</quota>
            <searchable>true</searchable>
            <system>false</system>
            <unlogged>false</unlogged>
        </visibility>
        <definition>#"SYSTEM_SYSRULES_fileUploadField_v1"(
  showWhen: ri!showWhen,
  label: a!defaultValue(
    value: ri!label,
    default: "File"
  ),
  required: a!defaultValue(
    value: ri!required,
    default: false
  ),
  maxSelections: ri!maxSelections,
  labelPosition: if(isnull(ri!label),"COLLAPSED","ABOVE"),
  target: a!defaultValue(
    value: ri!documentFolder,
    default: #"_a-0000ed87-2144-8000-9bee-011c48011c48_1464553"
  ),
  value: ri!documents,
  saveInto: ri!documents,
  validations: a!localVariables(
    local!invalidExtensions: difference(
      upper(fv!files.extension), 
      a!defaultValue(
        value: ri!allowedFileTypes,
        default: #"_a-0000ee0e-a4b3-8000-9bf2-011c48011c48_1524665"
      )
    ),
    if(
      length(local!invalidExtensions) &gt; 0, 
      #"urn:appian:translation-string:v1:eba045ca-dca1-4dd5-98d3-7de759e8de2b"(#"urn:appian:translation-variable:v1:8fb9b546-6330-4be1-bf59-96c2b4d78c1a": #"_a-0000ee0e-a4b3-8000-9bf2-011c48011c48_1524665") &amp; 
      index(fv!files, "name", wherecontains(local!invalidExtensions, upper(fv!files.extension)), {}), 
      ""
    )
  )
)</definition>
        <namedTypedValue>
