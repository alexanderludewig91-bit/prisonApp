                <a:ruleInputTestConfigs>
                    <a:value xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:type="a:Expression">"Issue Payment"</a:value>
                    <a:nameRef>taskTypeName</a:nameRef>
