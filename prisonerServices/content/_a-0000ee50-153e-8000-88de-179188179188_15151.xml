<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<contentHaul xmlns:a="http://www.appian.com/ae/types/2009">
    <versionUuid>_a-0000ee50-153e-8000-88de-179188179188_15240</versionUuid>
    <rule>
        <name>PS_DR_TaskTypeTranslation</name>
        <uuid>_a-0000ee50-153e-8000-88de-179188179188_15151</uuid>
        <description>Map translations of taskTypes</description>
        <parentUuid>4e30e89d-6b0d-415f-8a87-1107bebc8692</parentUuid>
        <visibility>
            <advertise>false</advertise>
            <hierarchy>true</hierarchy>
            <indexable>true</indexable>
            <quota>false</quota>
            <searchable>true</searchable>
            <system>false</system>
            <unlogged>false</unlogged>
        </visibility>
        <definition>a!match(
  value: ri!taskTypeName,
  equals: "Review Stipend",
  then: "Teilhabegeldantrag Prüfen",
  equals: "Review Generic",
  then: "Sonstiges Anliegen-Antrag Prüfen",
  equals: "Answer Question",
  then: "Rückfrage beantworten",
  equals: "Issue Payment",
  then: "Auszahlung Durchführen",
  equals: "Personal Notification",
  then: "Persönliche Eröffnung",
  default: "Unbekannte Aufgabentyp"
)</definition>
        <namedTypedValue>
            <name>taskTypeName</name>
            <type>
                <name>string</name>
                <namespace>http://www.w3.org/2001/XMLSchema</namespace>
            </type>
            <value/>
        </namedTypedValue>
        <preferredEditor>legacy</preferredEditor>
        <offlineEnabled>false</offlineEnabled>
    </rule>
