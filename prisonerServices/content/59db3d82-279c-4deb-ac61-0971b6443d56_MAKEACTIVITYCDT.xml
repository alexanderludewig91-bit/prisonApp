    <rule>
        <name>PS_CreateActivityCDT</name>
        <uuid>59db3d82-279c-4deb-ac61-0971b6443d56_MAKEACTIVITYCDT</uuid>
        <description>Formatting rule that generates the activity history for a particular process [Activity History]</description>
        <parentUuid>bb69cd5d-2b14-4fb7-b9d0-11ebd5815cda</parentUuid>
        <visibility>
            <advertise>false</advertise>
            <hierarchy>true</hierarchy>
            <indexable>true</indexable>
            <quota>false</quota>
            <searchable>true</searchable>
            <system>false</system>
            <unlogged>false</unlogged>
        </visibility>
        <definition>'type!{urn:com:appian:types:PS}PS_Activity'(
  recordId: ri!recordId,
  who: ri!who,
  action: ri!action,
  /* Use a different Details pattern for each type of activity */
  details:if(
    ri!action = #"_a-0000ed02-f63d-8000-9bea-011c48011c48_1058628",
    "To: " &amp; #"28845323-04ee-4e83-9c6c-cd99b14e142b_FORMATNAME"(ri!taskAssignee) &amp; char(10) &amp; "Details: " &amp; ri!taskDetails &amp; if(
      isnull(ri!taskDeadline),
      "",
      char(10) &amp; "Deadline: " &amp; ri!taskDeadline
    ),
    if(
      or(ri!action = #"b1bcb3b4-5035-4ffc-b897-b0827c9cf76e_ACTIONCOMPLETED", ri!action = #"35beec5b-7eb3-4ebc-9c67-03ff6e89ce2f_ACTIONSKIPPED"),
      "From: " &amp; #"28845323-04ee-4e83-9c6c-cd99b14e142b_FORMATNAME"(ri!taskAssigner) &amp; char(10) &amp; if(isnull(ri!comments), "(No Comments)", "Comments: " &amp; ri!comments),
      if(
        ri!action = #"_a-0000ed02-f63d-8000-9bea-011c48011c48_1058624",
        "Message: " &amp; ri!message &amp; if(not(isnull(ri!attachment)), char(10) &amp; "Attachment: " &amp; #"_a-0000ed02-f63d-8000-9bea-011c48011c48_1058680"(ri!attachment), ""),
        if(
          or(ri!action = #"_a-0000ed02-f63d-8000-9bea-011c48011c48_1058620", ri!action = #"_a-0000ed02-f63d-8000-9bea-011c48011c48_1058636"),
          #"_a-0000ed02-f63d-8000-9bea-011c48011c48_1058720"(
            oldCDT: ri!oldCDT,
            newCDT: ri!newCDT,
            fields: #"_a-0000ed02-f63d-8000-9bea-011c48011c48_1058804",
            fieldNames: #"_a-0000ed02-f63d-8000-9bea-011c48011c48_1058800",
            fieldTypes: #"_a-0000ed02-f63d-8000-9bea-011c48011c48_1058808"
          ) &amp; if(
            or(isnull(ri!newDocs), count(ri!newDocs)=0),
            "",
            "Attached Files: " &amp; joinarray(apply(#"_a-0000ed02-f63d-8000-9bea-011c48011c48_1058680", ri!newDocs), ", ") &amp; char(10)
          ) &amp; if(
            or(isnull(ri!deletedDocs), count(ri!deletedDocs)=0),
            "",
            "Deleted Files: " &amp; joinarray(apply(#"_a-0000ed02-f63d-8000-9bea-011c48011c48_1058680", ri!deletedDocs), ", ")
          ),
          "no activity found"
        )
      )
    )
  ),
  when: now()
)</definition>
