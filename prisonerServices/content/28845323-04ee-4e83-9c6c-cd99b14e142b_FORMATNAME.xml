<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<contentHaul xmlns:a="http://www.appian.com/ae/types/2009">
    <versionUuid>_a-0000ee0e-a4b3-8000-9bf2-011c48011c48_1623627</versionUuid>
    <rule>
        <name>PS_FormatName</name>
        <uuid>28845323-04ee-4e83-9c6c-cd99b14e142b_FORMATNAME</uuid>
        <description>Formatting rule that, from a username, returns that user's display name in a formatted string [Base]</description>
        <parentUuid>90d38322-a009-41ca-9890-e4f474c93ac7</parentUuid>
        <visibility>
            <advertise>false</advertise>
            <hierarchy>true</hierarchy>
            <indexable>true</indexable>
            <quota>false</quota>
            <searchable>true</searchable>
            <system>false</system>
            <unlogged>false</unlogged>
        </visibility>
        <definition>if(
  and(not(isnull(ri!username)), isusernametaken(ri!username)),
  user(ri!username, "firstName") &amp; " " &amp; user(ri!username, "lastName"),
  ri!username
)
</definition>
        <namedTypedValue>
            <name>username</name>
            <type>
                <name>string</name>
                <namespace>http://www.w3.org/2001/XMLSchema</namespace>
            </type>
            <value/>
        </namedTypedValue>
        <preferredEditor>legacy</preferredEditor>
        <offlineEnabled>false</offlineEnabled>
    </rule>
    <roleMap public="true">
        <role inherit="true" allowForAll="false" name="readers">
