    <rule>
        <name>PS_DocumentNameLimitTo90Chars</name>
        <uuid>_a-0000ee0e-a4b3-8000-9bf2-011c48011c48_1530530</uuid>
        <description></description>
        <parentUuid>4e30e89d-6b0d-415f-8a87-1107bebc8692</parentUuid>
        <visibility>
            <advertise>false</advertise>
            <hierarchy>true</hierarchy>
            <indexable>true</indexable>
            <quota>false</quota>
            <searchable>true</searchable>
            <system>false</system>
            <unlogged>false</unlogged>
        </visibility>
        <definition>if(
  a!isNullOrEmpty(ri!document),
  "No Document Name found",
  left(
    document(ri!document, "name"),
    90 - (
      1 + len(
        document(ri!document, "extension")
      )
    )
  )
)</definition>
        <namedTypedValue>
            <name>document</name>
            <type>
                <name>CollaborationDocument</name>
                <namespace>http://www.appian.com/ae/types/2009</namespace>
            </type>
        </namedTypedValue>
        <preferredEditor>legacy</preferredEditor>
        <offlineEnabled>false</offlineEnabled>
    </rule>
