    <rule>
        <name>PS_DR_FormatUserName</name>
        <uuid>_a-0000ee0e-a4b3-8000-9bf2-011c48011c48_1535179</uuid>
        <description>Formats a userName into: "lastName, firstName"</description>
        <parentUuid>4e30e89d-6b0d-415f-8a87-1107bebc8692</parentUuid>
        <visibility>
            <advertise>false</advertise>
            <hierarchy>true</hierarchy>
            <indexable>true</indexable>
            <quota>false</quota>
            <searchable>true</searchable>
            <system>false</system>
            <unlogged>false</unlogged>
        </visibility>
        <definition>if(
  and(not(isnull(ri!username)), isusernametaken(ri!username)),
  user(ri!username, "lastName") &amp; ", " &amp; user(ri!username, "firstName"),
  ri!username
)
</definition>
        <namedTypedValue>
            <name>userName</name>
            <type>
                <name>string</name>
                <namespace>http://www.w3.org/2001/XMLSchema</namespace>
            </type>
            <value/>
        </namedTypedValue>
        <preferredEditor>legacy</preferredEditor>
        <offlineEnabled>false</offlineEnabled>
    </rule>
