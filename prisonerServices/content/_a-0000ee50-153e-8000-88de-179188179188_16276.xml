        <definition>if(
  and(
    isnull(ri!eventId),
    a!isNullOrEmpty(ri!attachmentIds)
  ),
  #"_a-0000ee0e-a4b3-8000-9bf2-011c48011c48_1617076"(recordType: #"urn:appian:record-type:v1:17ccedd3-4c03-4664-8a75-fd71ae87f3ce"),
  #"SYSTEM_SYSRULES_queryRecordType_v2"(
    recordType: #"urn:appian:record-type:v1:17ccedd3-4c03-4664-8a75-fd71ae87f3ce",
    pagingInfo: a!defaultValue(
      value: ri!pagingInfo,
      default: #"SYSTEM_SYSRULES_pagingInfo"(startIndex: 1, batchSize: 100)
    ),
    filters: #"SYSTEM_SYSRULES_queryLogicalExpression"(
      operator: "AND",
      ignoreFiltersWithEmptyValues: true,
      filters: {
        #"SYSTEM_SYSRULES_queryFilter"(
          field: #"urn:appian:record-field:v1:17ccedd3-4c03-4664-8a75-fd71ae87f3ce/354f153b-9e66-4694-a12f-7b254af55f30",
          operator: "=",
          value: ri!eventId
        ),
        #"SYSTEM_SYSRULES_queryFilter"(
          field: #"urn:appian:record-field:v1:17ccedd3-4c03-4664-8a75-fd71ae87f3ce/0b9f9459-c913-4e8e-86e6-73dfaf78c84a",
          operator: "in",
          value: ri!attachmentIds
        )
      }
    )
  )
)</definition>
