        <uuid>_a-0000ee0e-a4b3-8000-9bf2-011c48011c48_1616294</uuid>
        <description></description>
        <parentUuid>4e30e89d-6b0d-415f-8a87-1107bebc8692</parentUuid>
        <visibility>
            <advertise>false</advertise>
            <hierarchy>true</hierarchy>
            <indexable>true</indexable>
            <quota>false</quota>
            <searchable>true</searchable>
            <system>false</system>
            <unlogged>false</unlogged>
        </visibility>
        <definition>#"SYSTEM_SYSRULES_richTextDisplayField"(
  labelPosition: "COLLAPSED",
  showWhen: and(
    a!isNotNullOrEmpty(ri!label),
    ri!showWhen &lt;&gt; false
  ),
  preventWrapping: true,
  accessibilityText: ri!label,
  value: a!localVariables(
    local!sizes: {
      "SMALL",
      "STANDARD",
      "MEDIUM",
      "MEDIUM_PLUS",
      "LARGE",
      "LARGE_PLUS",
      "EXTRA_LARGE"
    },
    local!size: a!defaultValue(
      ri!size,
      "MEDIUM"
    ),
    local!larger: if(
      local!size = "EXTRA_LARGE",
      "EXTRA_LARGE",
      displayvalue(
        local!size,
        local!sizes,
        ldrop(
          local!sizes,
          1
        ),
        "EXTRA_LARGE"
      )
    ),
    {
      #"SYSTEM_SYSRULES_richTextIcon"(
        icon: ri!icon,
        size: local!larger,
        showWhen: a!isNotNullOrEmpty(
          ri!icon
        ),
      ),
      #"SYSTEM_SYSRULES_richTextItem_v1"(
        text: " ",
        showWhen: a!isNotNullOrEmpty(
          ri!icon
        )
      ),
      #"SYSTEM_SYSRULES_richTextItem_v1"(
        text: upper(
          mid(
            ri!label,
            1,
            1
          )
        ),
        size: local!larger,
        link: ri!link
      ),
      #"SYSTEM_SYSRULES_richTextItem_v1"(
        text: upper(
          mid(
            ri!label,
            2,
            len(
              ri!label
            )
          )
        ),
        size: local!size,
        link: ri!link
      ), 
    }
  )
)</definition>
        <namedTypedValue>
            <name>label</name>
            <type>
                <name>string</name>
                <namespace>http://www.w3.org/2001/XMLSchema</namespace>
            </type>
            <value/>
        </namedTypedValue>
        <namedTypedValue>
